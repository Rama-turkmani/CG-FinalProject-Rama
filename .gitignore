# ---- Editor / OS junk ------------------------------------------------------
.vscode/
.idea/
Thumbs.db
desktop.ini
.DS_Store

# ---- Local download of the upstream repo (temporary) -----------------------
Rama_Final_temp/

# ---- Vendored third-party libraries: keep them even though they contain .lib
!ThirdParty/
