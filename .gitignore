*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb

# ---- Compiler / linker artefacts -------------------------------------------
*.obj
*.o
*.exe
*.dll
*.lib
*.pdb
*.ilk
*.exp
*.tlog
*.log
